# PostgreSQL
POSTGRES_DB=careersuccex
POSTGRES_USER=careersuccex
POSTGRES_PASSWORD=careersuccex_secret

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Spring Boot
JWT_SECRET=change-me-to-a-long-random-secret-at-least-256-bits
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8080/api/v1/github/callback
ENCRYPTION_KEY=change-me-32-char-secret-key!!

# AI Service — pick ONE provider (see README)
# gemini | groq | grok | http (OpenAI-compatible URL, e.g. local Ollama)
AI_PROVIDER=grok

# Gemini (if AI_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq (if AI_PROVIDER=groq) — https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Grok / xAI (if AI_PROVIDER=grok) — https://console.x.ai
GROK_API_KEY=
GROK_MODEL=grok-4-1-fast-non-reasoning

# OpenAI-compatible HTTP endpoint (if AI_PROVIDER=http)
HTTP_LLM_BASE_URL=
HTTP_LLM_API_KEY=
HTTP_LLM_MODEL=

AI_SERVICE_URL=http://ai-service:8000

# Rate limits (per user per day, tracked in Redis)
CV_UPLOADS_PER_DAY=50
GITHUB_REFRESHES_PER_DAY=20

# Frontend
VITE_API_URL=http://localhost:8080/api/v1
APP_FRONTEND_URL=http://localhost:5173
